<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cricket Scorecard Overlay</title>
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }
        
        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Arial, sans-serif;
            background: transparent;
            color: #e6edf3;
            line-height: 1.6;
            padding: 32px 20px;
        }
        
        .setup-panel {
            max-width: 500px;
            margin: 0 auto;
        }
        
        .setup-panel h1 {
            font-size: 24px;
            margin-bottom: 4px;
        }
        
        .subtitle {
            color: #9fb0c0;
            margin-bottom: 24px;
            font-size: 14px;
        }
        
        .box {
            background: rgba(22, 27, 34, 0.95);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(42, 54, 69, 0.5);
            border-radius: 12px;
            padding: 18px 20px;
        }
        
        .form-group {
            margin-bottom: 16px;
        }
        
        label {
            display: block;
            font-size: 13px;
            color: #9fb0c0;
            margin-bottom: 6px;
        }
        
        input[type="text"] {
            width: 100%;
            box-sizing: border-box;
            padding: 10px 12px;
            border-radius: 8px;
            border: 1px solid #2a3645;
            background: #0d1117;
            color: #e6edf3;
            font-size: 15px;
            font-family: inherit;
        }
        
        input[type="text"]:focus {
            outline: none;
            border-color: #ff4136;
        }
        
        input[type="text"]::placeholder {
            color: #666;
        }
        
        .radio-group {
            display: flex;
            gap: 15px;
            margin-bottom: 10px;
        }
        
        .radio-group label {
            display: inline-flex;
            align-items: center;
            margin: 0;
            font-size: 14px;
            color: #e6edf3;
            cursor: pointer;
        }
        
        .radio-group input[type="radio"] {
            width: auto;
            margin-right: 6px;
            accent-color: #ff4136;
        }
        
        .theme-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(80px, 1fr));
            gap: 8px;
            margin-top: 8px;
        }
        
        .theme-btn {
            padding: 8px 12px;
            background: #0d1117;
            border: 1px solid #2a3645;
            border-radius: 6px;
            text-align: center;
            font-size: 12px;
            color: #e6edf3;
            cursor: pointer;
            transition: all 0.2s ease;
            text-transform: capitalize;
        }
        
        .theme-btn:hover {
            border-color: #ff4136;
            background: #1a2028;
        }
        
        .theme-btn.active {
            background: #ff4136;
            border-color: #ff4136;
            color: #fff;
        }
        
        .preview-label {
            display: block;
            font-size: 13px;
            color: #9fb0c0;
            margin-bottom: 6px;
            margin-top: 16px;
        }
        
        .url-preview {
            word-break: break-all;
            color: #7ee2a8;
            font-size: 13px;
            padding: 10px 12px;
            background: rgba(13, 17, 23, 0.5);
            border-radius: 6px;
            border: 1px solid rgba(42, 54, 69, 0.3);
            margin-bottom: 12px;
        }
        
        .btn-group {
            display: flex;
            gap: 12px;
        }
        
        .btn {
            flex: 1;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            padding: 10px 18px;
            border-radius: 8px;
            font-weight: 700;
            font-size: 15px;
            font-family: inherit;
            text-decoration: none;
            border: none;
            cursor: pointer;
            transition: all 0.2s ease;
        }
        
        .btn-primary {
            background: linear-gradient(135deg, #ff4136, #ff851b);
            color: #ffffff;
        }
        
        .btn-primary:hover {
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(255, 65, 54, 0.4);
        }
        
        .btn-secondary {
            background: #2a3645;
            color: #e6edf3;
        }
        
        .btn-secondary:hover {
            background: #3a4655;
        }
        
        .help-text {
            color: #9fb0c0;
            font-size: 14px;
            margin-top: 16px;
        }
        
        code {
            background: rgba(42, 54, 69, 0.5);
            border: 1px solid rgba(42, 54, 69, 0.8);
            border-radius: 4px;
            padding: 2px 6px;
            font-size: 13px;
        }
        
        .overlay {
            display: none;
        }
        
        .hidden {
            display: none !important;
        }
    </style>
</head>

<body>
    <div id="setup-panel" class="setup-panel">
        <h1>🏏 Cricket Scorecard Overlay</h1>
        <p class="subtitle">Configure your live scorecard overlay</p>
        
        <div class="box">
            <div class="form-group">
                <label>Match ID (CricClubs match ID)</label>
                <input type="text" id="match-id" placeholder="e.g., 2169">
            </div>
            
            <div class="form-group">
                <label>Club ID (CricClubs club ID)</label>
                <div class="radio-group">
                    <label>
                        <input type="radio" name="clubId" value="40319">
                        USACricketJunior
                    </label>
                    <label>
                        <input type="radio" name="clubId" value="48">
                        GPCL
                    </label>
                </div>
                <input type="text" id="club-id" placeholder="Enter custom Club ID (default: LPCL)">
            </div>
            
            <div class="form-group">
                <label>Theme</label>
                <div class="theme-grid" id="theme-grid">
                    <div class="theme-btn" data-theme="classic">classic</div>
                    <div class="theme-btn" data-theme="modern">modern</div>
                    <div class="theme-btn" data-theme="neon">neon</div>
                    <div class="theme-btn" data-theme="kkr">kkr</div>
                    <div class="theme-btn" data-theme="rcb">rcb</div>
                    <div class="theme-btn" data-theme="mi">mi</div>
                    <div class="theme-btn" data-theme="csk">csk</div>
                    <div class="theme-btn" data-theme="dc">dc</div>
                    <div class="theme-btn" data-theme="rr">rr</div>
                    <div class="theme-btn" data-theme="srh">srh</div>
                    <div class="theme-btn" data-theme="pbks">pbks</div>
                    <div class="theme-btn" data-theme="gt">gt</div>
                    <div class="theme-btn" data-theme="lsg">lsg</div>
                    <div class="theme-btn" data-theme="tel">tel</div>
                    <div class="theme-btn" data-theme="ted">ted</div>
                    <div class="theme-btn" data-theme="tul">tul</div>
                    <div class="theme-btn" data-theme="tud">tud</div>
                </div>
            </div>
            
            <label class="preview-label">Preview</label>
            <div class="url-preview" id="url-preview"></div>
            
            <div class="btn-group">
                <a href="#" class="btn btn-primary" id="open-btn">
                    <span>↗</span> Open
                </a>
                <button class="btn btn-secondary" id="copy-btn">
                    <svg style="vertical-align: middle; margin-right: 4px;" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
                    Copy
                </button>
            </div>
        </div>
        
        <p class="help-text">Add as a <strong>Browser Source</strong> in OBS (1920×1080, transparent). Match ID is <code>0</code> until live scoring starts.</p>
    </div>

    <div class="overlay">
        <img alt="Overlay" id="overlay-image" class="overlay-image" style="display: none;" width="120" height="120">

        <div id="result" class="score-overlay" style="display: none;">
            <div id="match-result"></div>
        </div>

        <div id="firstInnings" class="score-overlay">

            <div class="batting-team-info">
                <img id="batting-team-logo" class="team-logo" alt="Team Logo" width="60" height="60">
            </div>

            <div class="batsman-info" id="batsman-info">
                <div class="batsman-row">
                    <div class="batsman-name" id="batsman1-name"></div>
                    <div class="batsman-runs-balls" id="batsman1-runs-balls"></div>
                </div>
                <div class="batsman-row">
                    <div class="batsman-name" id="batsman2-name"></div>
                    <div class="batsman-runs-balls" id="batsman2-runs-balls"></div>
                </div>
            </div>

            <div class="scorecard-pill">
                <div class="team-name" id="team-name">Loading...</div>
                <div class="score-and-overs">
                    <span class="score" id="team-score"></span><span class="wickets" id="team-wickets"></span> <span
                        class="overs" id="team-overs"></span>
                </div>
            </div>

            <div class="bowler-info" id="bowler-info">
                <div class="bowler-row">
                    <div class="bowler-name" id="bowler-name"></div>
                    <div class="bowler-figures" id="bowler-figures">
                        <span id="bowler-wickets-runs"></span>
                        <span id="bowler-overs" class="bowler-overs-data"></span>
                    </div>
                </div>
                <div class="bowler-row">
                    <div class="ball-by-ball-container" id="ball-by-ball">
                        <!-- Ball indicators will be injected here -->
                    </div>
                </div>
            </div>

            <div class="bowling-team-info">
                <img id="bowling-team-logo" class="team-logo" alt="Team Logo" width="60" height="60">
            </div>

        </div>
        <div id="secondInnings" class="score-overlay">
            <div>
                <span id="second-team-name"></span>
                <span id="second-team-score"></span>/<span id="second-team-wickets"></span> <span
                    id="second-team-overs"></span>
            </div>
            <div class="spacer" id="score-needed"></div>
        </div>
    </div>

    <script>
        const setupPanel = document.getElementById('setup-panel');
        const overlay = document.querySelector('.overlay');
        const matchIdField = document.getElementById('match-id');
        const clubIdField = document.getElementById('club-id');
        const clubIdRadio = document.querySelectorAll('input[name="clubId"]');
        const themeGrid = document.getElementById('theme-grid');
        const urlPreview = document.getElementById('url-preview');
        const openBtn = document.getElementById('open-btn');
        const copyBtn = document.getElementById('copy-btn');
        
        let selectedTheme = 'modern';
        
        // Set default theme as active
        const defaultThemeBtn = themeGrid.querySelector('[data-theme="modern"]');
        if (defaultThemeBtn) {
            defaultThemeBtn.classList.add('active');
        }
        
        // Theme selection
        themeGrid.querySelectorAll('.theme-btn').forEach(btn => {
            btn.addEventListener('click', () => {
                themeGrid.querySelectorAll('.theme-btn').forEach(b => b.classList.remove('active'));
                btn.classList.add('active');
                selectedTheme = btn.dataset.theme;
                updateUrl();
            });
        });
        
        // Club ID radio selection
        clubIdRadio.forEach(radio => {
            radio.addEventListener('change', () => {
                if (radio.checked) {
                    clubIdField.value = radio.value;
                    updateUrl();
                }
            });
        });
        
        // Generate URL
        function generateUrl() {
            const matchId = matchIdField.value.trim() || '0';
            const clubId = clubIdField.value.trim() || 'LPCL';
            const theme = selectedTheme;
            
            const params = new URLSearchParams();
            params.set('matchId', matchId);
            params.set('clubId', clubId);
            params.set('theme', theme);
            
            const baseUrl = window.location.origin + window.location.pathname;
            return `${baseUrl}?${params.toString()}`;
        }
        
        // Update URL preview
        function updateUrl() {
            const url = generateUrl();
            urlPreview.textContent = new URL(url).href;
            openBtn.href = url;
        }
        
        // Event listeners
        matchIdField.addEventListener('input', updateUrl);
        clubIdField.addEventListener('input', () => {
            clubIdRadio.forEach(r => r.checked = false);
            updateUrl();
        });
        
        // Copy button
        copyBtn.addEventListener('click', async (e) => {
            e.preventDefault();
            const url = generateUrl();
            try {
                await navigator.clipboard.writeText(url);
                const originalText = copyBtn.innerHTML;
                copyBtn.textContent = 'Copied!';
                setTimeout(() => {
                    copyBtn.innerHTML = originalText;
                }, 2000);
            } catch (err) {
                const textArea = document.createElement('textarea');
                textArea.value = url;
                document.body.appendChild(textArea);
                textArea.select();
                document.execCommand('copy');
                document.body.removeChild(textArea);
                const originalText = copyBtn.innerHTML;
                copyBtn.textContent = 'Copied!';
                setTimeout(() => {
                    copyBtn.innerHTML = originalText;
                }, 2000);
            }
        });
        
        // Check if overlay mode
        const urlParams = new URLSearchParams(window.location.search);
        if (urlParams.has('matchId')) {
            setupPanel.classList.add('hidden');
            overlay.style.display = 'block';
        } else {
            updateUrl();
        }
    </script>

    <script src="/src/script.ts" type="module"></script>
</body>

</html>